# Copy this file to .env and fill in your values.
# docker compose automatically loads .env

# ── Docker Hub image ──────────────────────────────────────────────────────────
DOCKER_IMAGE=yourdockerhubname/wiki-qa:latest

# ── Security ──────────────────────────────────────────────────────────────────
# JWT secret — CHANGE THIS in production (use a long random string)
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Optional API key for X-API-Key header. Leave blank to disable.
API_KEY=

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: local (flan-t5-small, no API key needed), openai, anthropic
LLM_PROVIDER=local

# Required if LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Vector Store ─────────────────────────────────────────────────────────────
# Options: faiss (local, default), pinecone (serverless)
VECTOR_STORE=faiss

# Required if VECTOR_STORE=pinecone
PINECONE_API_KEY=
PINECONE_INDEX=wiki-qa

# ── Feature flags (set to "false" to save RAM on t2.micro) ───────────────────
ENABLE_RERANKER=true
ENABLE_GENERATOR=true

# ── EC2 deployment ────────────────────────────────────────────────────────────
# BACKEND_URL=http://<EC2_PUBLIC_IP>:8000

# ── Observability ─────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
